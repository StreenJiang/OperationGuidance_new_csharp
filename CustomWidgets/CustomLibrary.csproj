<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Update="Buttons\BaseClasses\CommonButtonBase.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Buttons\PageSwitchButton.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Panels\CustomChildMenuFirstPanel.cs" />
    <Compile Update="Panels\BaseClasses\CustomContentPanelBase.cs" />
    <Compile Update="Panels\AbstractClasses\AbstractCustomPanel.cs" />
    <Compile Update="Panels\AbstractClasses\AbstractCustomMenuPanel.cs" />
    <Compile Update="Panels\CustomContentPanel.cs" />
    <Compile Update="Panels\CustomMainMenuPanel.cs" />
    <Compile Update="Resources\CustomResources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>CustomResources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Buttons\Interfaces\" />
    <Folder Include="Panels\Interfaces\" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Resources\CustomResources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>CustomResources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

</Project>